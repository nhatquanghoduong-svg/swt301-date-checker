		"_postman_id": "datetime-checker-api-tests",
		"name": "DateTime Checker API Tests",
		"description": "Bộ test cases kiểm tra API /api/check-date cho ứng dụng Date Time Checker.\n\nCác nhóm test:\n1. Valid Dates - Ngày hợp lệ\n2. Invalid Format - Định dạng không hợp lệ\n3. Out of Range - Giá trị ngoài phạm vi\n4. Invalid Dates - Ngày không tồn tại\n5. Leap Year - Năm nhuận\n6. Boundary Values - Giá trị biên",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3001"
		}
	],
	"item": [
		{
			"name": "1. Valid Dates",
			"item": [
				{
					"name": "TC01 - Valid date: 15/6/2000",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has success=true', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.success).to.eql(true);",
									"});",
									"",
									"pm.test('Message contains correct date', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.message).to.include('is correct date time');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"day\": \"15\",\n    \"month\": \"6\",\n    \"year\": \"2000\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/check-date",
							"host": ["{{baseUrl}}"],
							"path": ["api", "check-date"]
						}
					}
				},
